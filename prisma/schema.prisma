  indentId           Int?            @unique @map("indent_id")
  indent             PurchaseIndent? @relation(fields: [indentId], references: [id])
  threePartyStatus   String?         @map("ThreePartyStatus")
  approvedVendorName String?         @map("Approved Vendor Name")
  approvedRate       String?         @map("Approved Rate")
  approvedDate       DateTime?       @map("Approved Date")
  haveToMakePo       String?         @map("Have To Make PO")

  vendorName1        String?   @map("Vendor Name 1")
  selectRateType1    String?   @map("Select Rate Type 1")
  rate1              String?   @map("Rate 1")
  withTaxOrNot1      String?   @map("With Tax or Not 1")
  taxValue1          String?   @map("Tax Value 1")
  paymentTerm1       String?   @map("Payment Term 1")
  technicalTag1      String?   @map("Technical Tag 1")
  whatsappNumber1    String?   @map("Whatsapp Number 1")
  emailId1           String?   @map("Email Id 1")
  advancePercentage1 Float?    @map("Advance Percentage 1")
  quotationNumber1   String?   @map("Quotation Number 1")
  quotationDate1     DateTime? @map("Quotation Date 1")
  packaging1         String?   @map("Packaging 1")
  alumina1           Float?    @map("Alumina 1")
  iron1              Float?    @map("Iron 1")
  sio21              Float?    @map("SiO2 1")
  cao1               Float?    @map("CaO 1")
  ap1                Float?    @map("AP 1")
  bd1                Float?    @map("BD 1")
  fineness1          Float?    @map("Fineness 1")
  transportType1     String?   @map("Transport Type 1")
  notes1             String?   @map("Notes 1")
  expectedDate1      String?   @map("Expected Date 1")

  vendorName2        String?   @map("Vendor Name 2")
  selectRateType2    String?   @map("Select Rate Type 2")
  rate2              String?   @map("Rate 2")
  withTaxOrNot2      String?   @map("With Tax or Not 2")
  taxValue2          String?   @map("Tax Value 2")
  paymentTerm2       String?   @map("Payment Term 2")
  technicalTag2      String?   @map("Technical Tag 2")
  whatsappNumber2    String?   @map("Whatsapp Number 2")
  emailId2           String?   @map("Email Id 2")
  advancePercentage2 Float?    @map("Advance Percentage 2")
  quotationNumber2   String?   @map("Quotation Number 2")
  quotationDate2     DateTime? @map("Quotation Date 2")
  packaging2         String?   @map("Packaging 2")
  alumina2           Float?    @map("Alumina 2")
  iron2              Float?    @map("Iron 2")
  sio22              Float?    @map("SiO2 2")
  cao2               Float?    @map("CaO 2")
  ap2                Float?    @map("AP 2")
  bd2                Float?    @map("BD 2")
  fineness2          Float?    @map("Fineness 2")
  transportType2     String?   @map("Transport Type 2")
  notes2             String?   @map("Notes 2")
  expectedDate2      String?   @map("Expected Date 2")

  vendorName3        String?   @map("Vendor Name 3")
  selectRateType3    String?   @map("Select Rate Type 3")
  rate3              String?   @map("Rate 3")
  withTaxOrNot3      String?   @map("With Tax or Not 3")
  taxValue3          String?   @map("Tax Value 3")
  paymentTerm3       String?   @map("Payment Term 3")
  technicalTag3      String?   @map("Technical Tag 3")
  whatsappNumber3    String?   @map("Whatsapp Number 3")
  emailId3           String?   @map("Email Id 3")
  advancePercentage3 Float?    @map("Advance Percentage 3")
  quotationNumber3   String?   @map("Quotation Number 3")
  quotationDate3     DateTime? @map("Quotation Date 3")
  packaging3         String?   @map("Packaging 3")
  alumina3           Float?    @map("Alumina 3")
  iron3              Float?    @map("Iron 3")
  sio23              Float?    @map("SiO2 3")
  cao3               Float?    @map("CaO 3")
  ap3                Float?    @map("AP 3")
  bd3                Float?    @map("BD 3")
  fineness3          Float?    @map("Fineness 3")
  transportType3     String?   @map("Transport Type 3")
  notes3             String?   @map("Notes 3")
  expectedDate3      String?   @map("Expected Date 3")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  @@map("purchase_threeParty")
}

// --- Step 4: Factory Approval (FactoryApprovals.jsx) -----------------------

model PurchaseFactoryApproval {
  id            Int             @id @default(autoincrement())
  indentId      Int?            @unique @map("indent_id")
  indent        PurchaseIndent? @relation(fields: [indentId], references: [id])
  technicalTag1 String?         @map("Technical Tag 1")
  technicalTag2 String?         @map("Technical Tag 2")
  technicalTag3 String?         @map("Technical Tag 3")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime?       @map("updated_at")

  @@map("purchase_factoryApproval")
}

// --- Step 5: Management Approval (ManagementApprovals.jsx) -----------------

model PurchaseManagementApproval {
  id                  Int             @id @default(autoincrement())
  indentId            Int?            @unique @map("indent_id")
  indent              PurchaseIndent? @relation(fields: [indentId], references: [id])
  vendor              String?         @map("Vendor")
  approvedVendorName  String?         @map("Approved Vendor Name")
  approvedRate        String?         @map("Approved Rate")
  approvedPaymentTerm String?         @map("Approved Payment Term")
  approvedDate        DateTime?       @map("Approved Date")
  withTaxOrNot4       String?         @map("With Tax or Not 4")
  taxValue4           String?         @map("Tax Value 4")
  aluminaPercent      Float?          @map("Alumina %")
  ironPercent         Float?          @map("Iron %")
  sio2Percent         Float?          @map("SiO2 %")
  caoPercent          Float?          @map("CaO %")
  apPercentAge        Float?          @map("AP Percent Age %")
  bdPercentAge        Float?          @map("BD Percent Age %")
  fineness            Float?          @map("Fineness")
  packaging           String?         @map("Packaging")
  transportType4      String?         @map("Transport Type 4")
  expectedDate4       String?         @map("Expected Date 4")
  haveToMakePo        String?         @map("Have To Make PO")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime?       @map("updated_at")

  @@map("purchase_managementApproval")
}

// --- Step 6: Generate PO (generate-po.jsx) ----------------------------------

model PurchaseGeneratePo {
  id                 Int             @id @default(autoincrement())
  indentId           Int?            @unique @map("indent_id")
  indent             PurchaseIndent? @relation(fields: [indentId], references: [id])
  poNumber           String?         @map("po_number")
  vendorName         String?         @map("Vendor name")
  rate               Float?          @map("Rate")
  leadTimeToLiftDays String?         @map("Lead Time To Lift (days)")
  totalQuantity      Float?          @map("Total Quantity")
  totalAmount        Float?          @map("Total Amount")
  poCopy             String?         @map("PO Copy")
  advanceToBePaid    String?         @map("Advance To Be Paid")
  toBePaidAmount     Float?          @map("To Be Paid Amount")
  whenToBePaidAmount DateTime?       @map("When To Be Paid Amount")
  status5            String?         @map("Status5")
  poNotes            String?         @map("PO Notes")
  packaging          String?         @map("Packaging")
  transportType      String?         @map("Transport Type")
  poItems            Json?           @map("PO Items")
  approvedQty        Float?          @map("Approved Qty")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime?       @map("updated_at")

  @@map("purchase_generatePo")
}

// --- Step 7: Arrange Logistics (ArrangeLogistics.jsx) -----------------------

model PurchaseArrangeLogistics {
  id                       Int             @id @default(autoincrement())
  indentId                 Int?            @unique @map("indent_id")
  indent                   PurchaseIndent? @relation(fields: [indentId], references: [id])
  logisticsOptions         Json?           @map("LogisticsOptions")
  selectedTransporter      Json?           @map("SelectedTransporter")
  selectedTransporterIndex Int?            @map("SelectedTransporterIndex")
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime?       @map("updated_at")

  @@map("purchase_arrangeLogistics")
}

// --- Step 8: Logistics Approval (LogisticsApproval.jsx) --------------------

model PurchaseLogisticsApproval {
  id                       Int             @id @default(autoincrement())
  indentId                 Int?            @unique @map("indent_id")
  indent                   PurchaseIndent? @relation(fields: [indentId], references: [id])
  transporterName          String?         @map("Transporter Name")
  transporterRate          Float?          @map("Transporter Rate")
  transpoterRateType       String?         @map("transpoter_rate_type")
  selectedTransporter      Json?           @map("SelectedTransporter")
  selectedTransporterIndex Int?            @map("SelectedTransporterIndex")
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime?       @map("updated_at")

  @@map("purchase_logisticsApproval")
}

// --- Step 9: PO Entry In Tally (tally-entry.jsx) ----------------------------
// This step is a pure checkbox toggle in the reference system — its own
// existence (createdAt) and updatedAt ARE the tracking signal here.

model PurchasePoEntry {
  id        Int             @id @default(autoincrement())
  indentId  Int?            @unique @map("indent_id")
  indent    PurchaseIndent? @relation(fields: [indentId], references: [id])
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime?       @map("updated_at")

  @@map("purchase_poEntry")
}

// --- Step 10: Advance Payment (Originals-billto-fill.jsx) ------------------

model PurchaseAdvancePayment {
  id        Int             @id @default(autoincrement())
  indentId  Int?            @unique @map("indent_id")
  indent    PurchaseIndent? @relation(fields: [indentId], references: [id])
  status5   String?         @map("Status5")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime?       @map("updated_at")

  @@map("purchase_advancePayment")
}

// --- Step 11: Lift (lift-material.jsx) — creates the Lift No row ----------
// This is the new "root" for all LIFT-ACCOUNTS-side steps below (linked by
// liftNo), the same way purchase_indent is the root for INDENT-PO-side steps.

model PurchaseLift {
  id                     Int             @id @default(autoincrement())
  indentId               Int?            @map("indent_id")
  indent                 PurchaseIndent? @relation(fields: [indentId], references: [id])
  liftNo                 String?         @map("Lift No")
  timestamp              DateTime?       @map("Timestamp")
  vendorName             String?         @map("Vendor Name")
  qty                    Float?          @map("Qty")
  rawMaterialName        String?         @map("Raw Material Name")
  billNo                 String?         @map("Bill No.")
  dateOfBill             DateTime?       @map("Date Of Bill")
  areaLifting            String?         @map("Area lifting")
  leadTimeToReachFactory Int?            @map("Lead Time To Reach Factory (days)")
  liftingQty             Float?          @map("Lifting Qty")
  type                   String?         @map("Type")
  transporterName        String?         @map("Transporter Name")
  truckNo                String?         @map("Truck No.")
  driverNo               String?         @map("Driver No.")
  biltyNo                String?         @map("Bilty No.")
  typeOfTransportingRate String?         @map("Type Of Transporting Rate")
  rate                   Float?          @map("Rate")
  billImage              String?         @map("Bill Image")
  truckQty               Float?          @map("Truck Qty")
  biltyImage             String?         @map("Bilty Image")
  testingCertificate     String?         @map("Testing Certificate")
  firmName               String?         @map("Firm Name")
  transporterRate        Float?          @map("Transporter Rate")
  transportingRate       Float?          @map("Transporting Rate")
  pendingPoQty           String?         @map("Pending PO Qty")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime?       @map("updated_at")

  receipt        PurchaseReceipt?
  unloadApproval PurchaseUnloadApproval?
  lab            PurchaseLab?
  bilty          PurchaseBilty?
  fullkitting    PurchaseFullkitting?
  mismatches     PurchaseMismatch[]

  @@map("purchase_lift")
}

// --- Step 12: Receipt / physical quality check (receipt-check.jsx) --------

model PurchaseReceipt {
  id                     Int           @id @default(autoincrement())
  liftId                 Int?          @unique @map("lift_id")
  lift                   PurchaseLift? @relation(fields: [liftId], references: [id])
  dateOfReceiving        DateTime?     @map("Date Of Receiving")
  totalBillQuantity      Float?        @map("Total Bill Quantity")
  actualQuantity         Float?        @map("Actual Quantity")
  totalBagsQty           Float?        @map("Total Bags Qty")
  physicalCondition      String?       @map("Physical Condition")
  moisture               String?       @map("Moisture")
  physicalImageOfProduct String?       @map("Physical Image Of Product")
  imageOfWeightSlip      String?       @map("Image Of Weight Slip")
  unloadApprovalRequired String?       @map("Unload Approval Required")
  unloadApprovalStatus   String?       @map("Unload Approval Status")
  unloadApprovalTrigger  String?       @map("Unload Approval Trigger")
  unloadApprovalRemarks  String?       @map("Unload Approval Remarks")
  unloadApprovalBy       String?       @map("Unload Approval By")
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime?     @map("updated_at")

  @@map("purchase_receipt")
}

// --- Step 13: Unload Approval (ManagementUnloadApproval.jsx, hidden tab) ---

model PurchaseUnloadApproval {
  id                    Int           @id @default(autoincrement())
  liftId                Int?          @unique @map("lift_id")
  lift                  PurchaseLift? @relation(fields: [liftId], references: [id])
  unloadApprovalStatus  String?       @map("Unload Approval Status")
  unloadApprovalRemarks String?       @map("Unload Approval Remarks")
  unloadApprovalBy      String?       @map("Unload Approval By")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime?     @map("updated_at")

  @@map("purchase_unloadApproval")
}

// --- Step 14: Lab testing (lab-testing.jsx) ---------------------------------

model PurchaseLab {
  id              Int           @id @default(autoincrement())
  liftId          Int?          @unique @map("lift_id")
  lift            PurchaseLift? @relation(fields: [liftId], references: [id])
  status          String?       @map("Status")
  dateOfTest      DateTime?     @map("Date Of Test")
  moisturePercent Float?        @map("Moisture Percent Age %")
  bdPercent       Float?        @map("BD Percent Age %")
  apPercent       Float?        @map("AP Percent Age %")
  aluminaPercent  Float?        @map("Alumina Percent Age %")
  ironPercent     Float?        @map("Iron Percent Age %")
  sieveAnalysis   Float?        @map("Sieve Analysis")
  loiPercent      Float?        @map("LOI %")
  sio2Percent     Float?        @map("SIO2 %")
  caoPercent      Float?        @map("CaO %")
  mgoPercent      Float?        @map("MgO %")
  tio2Percent     Float?        @map("TiO2 %")
  k2oNa2oPercent  Float?        @map("K2O + Na2O %")
  freeIronPercent Float?        @map("Free Iron %")
  reason          String?       @map("Reason")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime?     @map("updated_at")

  @@map("purchase_lab")
}

// --- Step 15: Bilty (BiltyPage.jsx) -----------------------------------------

model PurchaseBilty {
  id         Int           @id @default(autoincrement())
  liftId     Int?          @unique @map("lift_id")
  lift       PurchaseLift? @relation(fields: [liftId], references: [id])
  biltyNo    String?       @map("Bilty No.")
  biltyImage String?       @map("Bilty Image")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime?     @map("updated_at")

  @@map("purchase_bilty")
}

// --- Step 16: Mismatch (Mis-match.jsx) — core mismatch record + triage ---
// New Mismatch rows are actually created upstream (Lift, Receipt, Lab,
// Purchase Return, Debit Note, Accounts Audit all seed rows here); this
// table is the shared identity + triage-status record all of those, and
// Mis-match.jsx itself, read and update.

model PurchaseMismatch {
  id                 Int           @id @default(autoincrement())
  timestamp          DateTime?     @map("Timestamp")
  liftId             Int?          @map("lift_id")
  lift               PurchaseLift? @relation(fields: [liftId], references: [id])
  firmName           String?       @map("Firm Name")
  partyName          String?       @map("Party Name")
  productName        String?       @map("Product Name")
  qty                Float?        @map("Qty")
  type               String?       @map("Type")
  billNo             String?       @map("Bill No.")
  areaLifting        String?       @map("Area Lifting")
  truckNo            String?       @map("Truck No.")
  transporterName    String?       @map("Transporter Name")
  transporter        String?       @map("Transporter")
  billImage          String?       @map("Bill Image")
  biltyNo            String?       @map("Bilty No.")
  biltyImage         String?       @map("Bilty Image")
  typeOfRate         String?       @map("Type Of Rate")
  rate               Float?        @map("Rate")
  truckQty           Float?        @map("Truck Qty")
  weightSlip         String?       @map("Weight Slip")
  totalFreight       Float?        @map("Total Freight")
  testingCertificate String?       @map("Testing Certificate")
  status             String?       @map("Status")
  remarks            String?       @map("Remarks")
  rateDifference     Float?        @map("Rate Difference")
  quantityDifference Float?        @map("Quantity Difference")
  diffQty            Float?        @map("Diff Qty")
  qtyDiffStatus      String?       @map("Qty Diff Status")
  aluminaDifference  Float?        @map("Alumina Difference")
  ironDifference     Float?        @map("Iron Difference")
  apDifference       Float?        @map("AP Difference")
  bdDifference       Float?        @map("BD Difference")
  actionType         String?       @map("Action Type")
  coordinationStatus String?       @map("coordination_status")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime?     @map("updated_at")

  purchaseReturns      PurchasePurchaseReturn[]
  debitNotes           PurchaseDebitNote[]
  purchaserCoordinates PurchasePurchaserCoordinate[]
  aaAudits             PurchaseAAAudit[]
  aaRectifies          PurchaseAARectify[]
  aaReAudits           PurchaseAAReAudit[]
  aaTallyEntries       PurchaseAATallyEntry[]
  aaBillEntries        PurchaseAABillEntry[]
  auditHistories       PurchaseAuditHistory[]

  @@map("purchase_mismatch")
}

// --- Step 17: Purchase Return (PurchaseReturnPage.jsx) --------------------

model PurchasePurchaseReturn {
  id               Int               @id @default(autoincrement())
  mismatchId       Int?              @map("mismatch_id")
  mismatch         PurchaseMismatch? @relation(fields: [mismatchId], references: [id])
  timeStamp        DateTime?         @map("Time Stamp")
  purchaseReturnNo String?           @map("Purchase Return No.")
  poNo             String?           @map("Po No.")
  actionType       String?           @map("Action Type")
  partyName        String?           @map("Party Name")
  productName      String?           @map("Product Name")
  productRate      Float?            @map("Product Rate")
  qty              Float?            @map("Qty")
  totalQty         Float?            @map("Total Qty")
  totalReturnQty   Float?            @map("Total Return Qty")
  returnThisTime   Float?            @map("Return This Time")
