datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Login {
  id          Int       @id @default(autoincrement())
  username    String    @unique
  password    String
  role        String    @default("user")
  page_access String?
  firm_name   String
  last_login  DateTime?

  @@map("login")
}

// ----------------------------------------------------------------------------
// PURCHASE SYSTEM — per-page schema (LIVE — synced to the DB via `prisma db
// push`; tables for indent/hod-approval/three-party/factory-approval/
// management-approval are wired to real controllers, the rest are still
// schema-only ahead of their controllers being built)
// ----------------------------------------------------------------------------
// Progress/workflow-stage tracking uses each table's own createdAt (when
// this step's row was written) instead of the reference system's explicit
// PlannedN/ActualN timestamp pairs — those columns are intentionally NOT
// carried over below.
//
// updatedAt is NOT auto-managed (no `@updatedAt`) — it's nullable and stays
// NULL until the *next* stage's row is first created, at which point the
// controller for that next stage stamps THIS row's updatedAt with the next
// row's createdAt. E.g. purchase_indent.updatedAt is set to
// purchase_hodApproval.createdAt the moment HOD Approval is first submitted
// for that indent (not touched again on later edits to that HOD Approval
// row). This gives each stage a "when did this record last advance"
// timestamp for MIS/turnaround-time reporting, independent of ordinary
// field edits. A table with no downstream stage yet built (or a genuine
// dead-end, e.g. a rejection) simply keeps updatedAt = NULL forever.

model PurchaseFirm {
  id             String    @id @default(uuid())
  firmName       String?   @map("firm_name")
  dataName       String?   @map("data_name")
  address        String?
  billingAddress String?   @map("billing_address")
  gstin          String?
  pan            String?
  phone          String?
  email          String?
  poPrefix       String?   @map("po_prefix")
  lastPoId       Int?      @map("last_po_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  @@map("purchase_firm")
}

model PurchaseMaster {
  id               Int       @id @default(autoincrement())
  generatedBy      String?   @map("Generated By")
  vendorName       String?   @map("Vendor Name")
  rawMaterialName  String?   @map("Raw Material Name")
  typeOfIndent     String?   @map("Type Of Indent")
  typeOfRate       String?   @map("Type Of Rate")
  areaLifting      String?   @map("Area Lifting")
  type             String?   @map("Type")
  transporterName  String?   @map("Transporter Name")
  transporterName2 String?   @map("Transporter Name 2")
  firmName         String?   @map("Firm Name")
  typeOfKycForm    String?   @map("Type Of KYC Form")
  vendorNameKyc    String?   @map("Vendor Name KYC")
  productName      String?   @map("Product Name")
  fmsName          String?   @map("Fms Name")
  rateType         String?   @map("Rate Type")
  paymentTerm      String?   @map("Payment Term")
  uom              String?   @map("UOM")
  gstNumber        String?   @map("GST Number")
  bankAccountNo    String?   @map("Current Bank A.C. No")
  ifscCode         String?   @map("IFSC Code")
  phoneNumber      String?   @map("Phone Number")
  email            String?   @map("Email")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @map("updated_at")

  @@map("purchase_master")
}

model PurchaseToleranceLimit {
  id        Int       @id @default(autoincrement())
  sNo       Int?      @map("S.No.")
  name      String?   @map("NAME")
  poAlumina Float?    @map("Po Alumina")
  poIron    Float?    @map("Po Iron")
  tlAlumina Float?    @map("TL Alumina")
  tlIron    Float?    @map("TL Iron")
  bdPercent Float?    @map("BD%")
  apPercent Float?    @map("AP%")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  @@map("purchase_toleranceLimit")
}

// --- Step 1: Indent (IndentForm.jsx) — creates the RI row ------------------

model PurchaseIndent {
  id                       Int       @id @default(autoincrement())
  indentId                 String?   @map("Indent Id.")
  timestamp                DateTime? @map("Timestamp")
  firmName                 String?   @map("Firm Name")
  generatedBy              String?   @map("Generated By")
  material                 String?   @map("Material")
  quantity                 Float?    @map("Quantity")
  currentStockAsPerFactory Float?    @map("Current Stock As Per factory")
  priority                 String?   @map("Priority")
  typeOfIndent             String?   @map("Type Of Indent")
  deliveryOrderNo          String?   @map("Delivery Order No.")
  notes                    String?   @map("Notes")
  uom                      String?   @map("UOM")
  expectedRequirementDate  DateTime? @map("expected_requierment_date")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime? @map("updated_at")

  hodApproval        PurchaseHodApproval?
  threeParty         PurchaseThreeParty?
  factoryApproval    PurchaseFactoryApproval?
  managementApproval PurchaseManagementApproval?
  generatePo         PurchaseGeneratePo?
  arrangeLogistics   PurchaseArrangeLogistics?
  logisticsApproval  PurchaseLogisticsApproval?
  poEntry            PurchasePoEntry?
  advancePayment     PurchaseAdvancePayment?
  lifts              PurchaseLift[]

  @@map("purchase_indent")
}

// --- Step 2: HOD Approval (StockApproval.jsx) ------------------------------

model PurchaseHodApproval {
  id             Int             @id @default(autoincrement())
  indentId       Int?            @unique @map("indent_id")
  indent         PurchaseIndent? @relation(fields: [indentId], references: [id])
  approvedQty    Float?          @map("Approved Qty")
  approvalStatus String?         @map("Approval Status")
  remarks        String?         @map("Remarks")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime?       @map("updated_at")

  @@map("purchase_hodApproval")
}

// --- Step 3: Three Party (ThreeParty.jsx) -----------------------------------
