datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Login {
  id          Int       @id @default(autoincrement())
  username    String    @unique
  password    String
  role        String    @default("user")
  page_access String?
  firm_name   String
  last_login  DateTime?

  @@map("login")
}


model Firm {
  id              Int     @id @default(autoincrement())
  firm_name       String?
  data_name       String?
  address         String?
  billing_address String?
  phone           String?
  gstin           String?
  pan             String?

  @@map("Firms")
}

model IndentPO {
  id     Int     @id @default(autoincrement())
  poNumber String? @map("po_number")

  timestamp   DateTime? @map("Timestamp")
  indentId    String?   @map("Indent Id.")
  firmName    String?   @map("Firm Name")
  vendor      String?   @map("Vendor")
  vendorName  String?   @map("Vendor name")
  generatedBy String?   @map("Generated By")
  material    String?   @map("Material")

  quantity      Float?  @map("Quantity")
  totalQuantity Float?  @map("Total Quantity")
  approvedQty   Float?  @map("Approved Qty")
  currentStock  Float?  @map("Current Stock As Per factory")
  priority      String? @map("Priority")
  typeOfIndent  String? @map("Type Of Indent")
  deliveryOrderNo String? @map("Delivery Order No.")
  notes         String? @map("Notes")
  poNotes       String? @map("PO Notes")
  uom           String? @map("UOM")
  expectedRequirementDate DateTime? @map("expected_requierment_date")

  status        String? @map("Status")
  rate          Float?  @map("Rate")
  totalAmount   Float?  @map("Total Amount")
  poCopy        String? @map("PO Copy")
  transportType String? @map("Transport Type")
  destination   String? @map("destination")

  advanceToBePaid    String?   @map("Advance To Be Paid")
  toBePaidAmount     Float?    @map("To Be Paid Amount")
  whenToBePaidAmount DateTime? @map("When To Be Paid Amount")
  packaging          String?   @map("Packaging")
  poItems            Json?     @map("PO Items")
  aluminaPercent     Float?    @map("Alumina %")
  ironPercent        Float?    @map("Iron %")
  apPercent          Float?    @map("AP Percent Age %")
  bdPercent          Float?    @map("BD Percent Age %")

  planned1 DateTime? @map("Planned1")
  actual1  DateTime? @map("Actual1")
  planned2 DateTime? @map("Planned2")
  actual2  DateTime? @map("Actual2")
  planned3 DateTime? @map("Planned3")
  actual3  DateTime? @map("Actual3")
  planned4 DateTime? @map("Planned4")
  actual4  DateTime? @map("Actual4")
  planned5 DateTime? @map("Planned5")
  actual5  DateTime? @map("Actual5")
  planned6 DateTime? @map("Planned6")
  actual6  DateTime? @map("Actual6")
  planned7 DateTime? @map("Planned7")
  actual7  DateTime? @map("Actual7")
  planned8 DateTime? @map("Planned8")
  actual8  DateTime? @map("Actual8")
  planned9 DateTime? @map("Planned9")
  actual9  DateTime? @map("Actual9")
  plannedLogistics DateTime? @map("PlannedLogistics")
  actualLogistics  DateTime? @map("ActualLogistics")

  approvalStatus     String?   @map("Approval Status")
  remarks            String?   @map("Remarks")
  approvedVendorName String?   @map("Approved Vendor Name")
  approvedRate       String?   @map("Approved Rate")
  approvedPaymentTerm String?  @map("Approved Payment Term")
  approvedDate       DateTime? @map("Approved Date")
  haveToMakePo       String?   @map("Have To Make PO")
  threePartyStatus   String?   @map("ThreePartyStatus")
  orderCancelQty     Float?    @map("Order Cancel Qty")
  reasonOfCancelQty  String?   @map("Reason Of Cancel Qty")
  pendingPoQty       String?   @map("Pending PO Qty")
  leadTimeToLift     String?   @map("Lead Time To Lift (days)")
  currentStockLevel  String?   @map("Current Stock")

  // Three-party vendor comparison slots (1-3)
  vendorName1        String? @map("Vendor Name 1")
  rate1               String? @map("Rate 1")
  selectRateType1     String? @map("Select Rate Type 1")
  withTaxOrNot1       String? @map("With Tax or Not 1")
  taxValue1           String? @map("Tax Value 1")
  paymentTerm1        String? @map("Payment Term 1")
  technicalTag1       String? @map("Technical Tag 1")
  vendorName2         String? @map("Vendor Name 2")
  rate2               String? @map("Rate 2")
  technicalTag2       String? @map("Technical Tag 2")
  vendorName3         String? @map("Vendor Name 3")
  rate3               String? @map("Rate 3")
  technicalTag3       String? @map("Technical Tag 3")

  logisticsOptions          Json?   @map("LogisticsOptions")
  selectedTransporter       Json?   @map("SelectedTransporter")
  selectedTransporterIndex  Int?    @map("SelectedTransporterIndex")
  transporterName           String? @map("Transporter Name")
  transporterRate           Float?  @map("Transporter Rate")
  transpoterRateType        String? @map("transpoter_rate_type")

  @@map("INDENT-PO")
}

model LiftAccount {
  id     Int     @id @default(autoincrement())
  timestamp DateTime? @map("Timestamp")

  liftNo         String? @map("Lift No")
  indentNo       String? @map("Indent no.")
  vendorName     String? @map("Vendor Name")
  rawMaterialName String? @map("Raw Material Name")
  type           String? @map("Type")
  qty            Float?  @map("Qty")
  liftingQty     Float?  @map("Lifting Qty")
  billNo         String? @map("Bill No.")
  dateOfBill     String? @map("Date Of Bill")
  areaLifting    String? @map("Area lifting")
  truckNo        String? @map("Truck No.")
  driverNo       String? @map("Driver No.")
  transporterName String? @map("Transporter Name")
  transporterRate Float?  @map("Transporter Rate")
  typeOfTransportingRate String? @map("Type Of Transporting Rate")
  rate           Float?  @map("Rate")
  billImage      String? @map("Bill Image")
  truckQty       Float?  @map("Truck Qty")
  biltyNo        String? @map("Bilty No.")
  biltyImage     String? @map("Bilty Image")
  firmName       String? @map("Firm Name")

  plannedOne  DateTime? @map("Planned 1")
  actualOne   DateTime? @map("Actual 1")
  plannedTwo  DateTime? @map("Planned 2")
  actualTwo   DateTime? @map("Actual 2")
  plannedThree DateTime? @map("Planned 3")
  actualThree DateTime? @map("Actual 3")

  dateOfReceiving   String? @map("Date Of Receiving")
  totalBillQuantity Float?  @map("Total Bill Quantity")
  actualQuantity    Float?  @map("Actual Quantity")
  physicalCondition String? @map("Physical Condition")
  moisture          String? @map("Moisture")
  weightSlip        String? @map("Image Of Weight Slip")

  status         String? @map("Status")
  dateOfTest     DateTime? @map("Date Of Test")
  moisturePercent Float? @map("Moisture Percent Age %")
  bdPercent      Float?  @map("BD Percent Age %")
  apPercent      Float?  @map("AP Percent Age %")
  aluminaPercent Float?  @map("Alumina Percent Age %")
  ironPercent    Float?  @map("Iron Percent Age %")

  unloadApprovalRequired String? @map("Unload Approval Required")
  unloadApprovalStatus   String? @map("Unload Approval Status")

  @@map("LIFT-ACCOUNTS")
}

model Mismatch {
  id       Int     @id @default(autoincrement())
  timestamp DateTime? @map("Timestamp")

  liftId          String? @map("Lift ID")
  liftNumber      String? @map("Lift Number")
  indentNumber    String? @map("Indent Number")
  firmName        String? @map("Firm Name")
  partyName       String? @map("Party Name")
  productName     String? @map("Product Name")
  qty             Float?  @map("Qty")
  billNo          String? @map("Bill No.")
  areaLifting     String? @map("Area Lifting")
  truckNo         String? @map("Truck No.")
  transporterName String? @map("Transporter Name")
  billImage       String? @map("Bill Image")
  biltyNo         String? @map("Bilty No.")
  rate            Float?  @map("Rate")
  truckQty        Float?  @map("Truck Qty")
  biltyImage      String? @map("Bilty Image")
  weightSlip      String? @map("Weight Slip")
  totalFreight    Float?  @map("Total Freight")

  status  String? @map("Status")
  status2 String? @map("Status2")
  status3 String? @map("Status3")
  status4 String? @map("Status4")
  status5 String? @map("Status5")
  status6 String? @map("Status6")
  remarks  String? @map("Remarks")
  remarks2 String? @map("Remarks2")
  remarks3 String? @map("Remarks3")
  remarks4 String? @map("Remarks4")
  remarks5 String? @map("Remarks5")
  remarks6 String? @map("Remarks6")

  planned2 DateTime? @map("Planned2")
  actual2  DateTime? @map("Actual2")
  planned3 DateTime? @map("Planned3")
  actual3  DateTime? @map("Actual3")
  planned4 DateTime? @map("Planned4")
  actual4  DateTime? @map("Actual4")
  planned5 DateTime? @map("Planned5")
  actual5  DateTime? @map("Actual5")
  planned6 DateTime? @map("Planned6")
  actual6  DateTime? @map("Actual6")
  planned7 DateTime? @map("Planned7")
  actual7  DateTime? @map("Actual7")

  rateDifference     Float? @map("Rate Difference")
  quantityDifference Float? @map("Quantity Difference")
  diffQty            Float? @map("Diff Qty")
  qtyDiffStatus      String? @map("Qty Diff Status")
  aluminaDifference  Float? @map("Alumina Difference")
  ironDifference     Float? @map("Iron Difference")
  apDifference       Float? @map("AP Difference")
  bdDifference       Float? @map("BD Difference")

  actionType          String? @map("Action Type")
  coordinationStatus  String? @map("coordination_status")
  debitAmount         Float?  @map("Debit Amount")
  debitNoteUrl        String? @map("Debit Note URL")
  purchaseReturnNo    String? @map("Purchase Return No.")

  @@map("Mismatch")
}

model Fullkitting {
  id     Int     @id @default(autoincrement())
  liftNo String? @map("Lift No")
  indentNo String? @map("Indent No")
  fmsName  String? @map("Fms Name")
  status   String? @map("Status")
  transporterName String? @map("Transporter Name")
  vehicleNumber   String? @map("Vehicle Number")
  from            String? @map("From")
  to              String? @map("To")
  materialLoadDetails String? @map("Material Load Details")
  biltyNumber     String? @map("Bilty Number")
  rateType        String? @map("Rate Type")
  amount          Float?  @map("Amount")
  biltyImage      String? @map("Bilty Image")
  transporterBillImage String? @map("Transporter Bill Image")
  fullkittingRemarks String? @map("Fullkitting Remarks")
  timestamp       DateTime? @map("Timestamp")
  createdAt       DateTime? @map("created_at")

  @@map("fullkittin")
}

model ToleranceLimit {
  id        Int     @id @default(autoincrement())
  name      String? @map("NAME")
  tlAlumina Float?  @map("TL Alumina")
  tlIron    Float?  @map("TL Iron")
  apPercent Float?  @map("AP%")
  bdPercent Float?  @map("BD%")

  @@map("TL")
}

model Master {
  id                  Int     @id @default(autoincrement())
  vendorName          String? @map("Vendor Name")
  rawMaterialName     String? @map("Raw Material Name")
  generatedBy         String? @map("Generated By")
  typeOfIndent        String? @map("Type Of Indent")
  firmName            String? @map("Firm Name")
  areaLifting         String? @map("Area Lifting")
  type                String? @map("Type")
  transporterName     String? @map("Transporter Name")
  transporterName2    String? @map("Transporter Name 2")
  transportRateType   String? @map("Transport Rate Type")
  transportRate       String? @map("Transport Rate")
  typeOfKycForm       String? @map("Type Of KYC Form")
  vendorNameKyc       String? @map("Vendor Name KYC")
  productName         String? @map("Product Name")
  gstNumber           String? @map("GST Number")
  bankAccountNo       String? @map("Current Bank A.C. No")
  ifscCode            String? @map("IFSC Code")
  phoneNumber         String? @map("Phone Number")
  email               String? @map("Email")
  uom                 String? @map("UOM")

  @@map("Master")
}

model PurchaserCoordinate {
  id               String    @id @default(uuid())
  po_number        String?
  type             String?
  vendor_name      String?
  transporter_name String?
  material_name    String?
  mismatch_id      Int?
  status           String?   @default("PENDING")
  coordinated_by   String?
  coordinated_at   DateTime?
  created_at       DateTime? @default(now())

  @@map("purchaser_coordinates")
}

model PurchaseReturn {
  id  Int @id @default(autoincrement()) @map("ID")

  timeStamp        DateTime? @map("Time Stamp")
  purchaseReturnNo String?   @map("Purchase Return No.")
  poNo             String?   @map("Po No.")
  actionType       String?   @map("Action Type")
  partyName        String?   @map("Party Name")
  productName      String?   @map("Product Name")
  productRate      Float?    @map("Product Rate")
  qty              Float?    @map("Qty")
  totalQty         Float?    @map("Total Qty")
  totalReturnQty   Float?    @map("Total Return Qty")
  returnThisTime   Float?    @map("Return This Time")
  returnReason     String?   @map("Return Reason")
  transport        String?   @map("Transport")
  typeOfTransport  String?   @map("Type of Transport")
  vehicleNo        String?   @map("Vehicle No")
  builtyNo         String?   @map("Builty No")
  rateType         String?   @map("Rate Type")
  amount           String?   @map("Amount")
  billNo           String?   @map("Bill No")
  orgBillNo        String?   @map("Org. Bill No")
  billImage        String?   @map("Bill Image")
  liftNo           String?   @map("Lift No")
  firmName         String?   @map("Firm Name")
  mismatchId       Int?      @map("mismatch_id")
  creditNoteUrl    String?   @map("Credit Note URL")

  @@map("Purchase Returns")
}
