// --- Parallel financial track A: Make PI / Received PI Payment -----------

model OrderPiRecord {
  id             Int       @id @default(autoincrement())
  poNumber       String?   @map("po_number")
  poIds          Int[]     @map("po_ids") // OrderReceipt ids this PI covers — array FK, no formal relation (matches reference)
  piNumber       String?   @map("pi_number")
  partyName      String?   @map("party_name")
  firmName       String?   @map("firm_name")
  piType         String?   @map("pi_type")
  productNames   String[]  @map("product_names")
  slabLabel      String?   @map("slab_label")
  slabPct        Float?    @map("slab_pct")
  totalPoValue   Float?    @map("total_po_value")
  expectedAmount Float?    @map("expected_amount")
  piQuantity     Float?    @map("pi_quantity")
  dueDate        DateTime? @map("due_date")
  notes          String?   @map("notes")
  status         String?   @default("Pending") @map("status") // 'Pending' | 'Partial' | 'Received'
  piCopy         Json?     @map("pi_copy") // {rowId: url} map, kept as-is from reference
  actualAmount   Float?    @default(0) @map("actual_amount")
  receivedDate   DateTime? @map("received_date")
  receivedAt     DateTime? @map("received_at")
  remarks        String?   @map("remarks")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  paymentLogs    OrderPiPaymentLog[]
  rescheduleLogs OrderPiRescheduleLog[]

  @@map("order_piRecord")
}

model OrderPiPaymentLog {
  id         Int            @id @default(autoincrement())
  piRecordId Int?           @map("pi_record_id")
  piRecord   OrderPiRecord? @relation(fields: [piRecordId], references: [id])
  amount     Float?         @map("amount")
  date       DateTime?      @map("date")
  remarks    String?        @map("remarks")
  type       String?        @map("type") // e.g. 'Mark Received' | 'Partial Payment'
  recordedAt DateTime       @default(now()) @map("recorded_at")

  @@map("order_piPaymentLog")
}

model OrderPiRescheduleLog {
  id            Int            @id @default(autoincrement())
  piRecordId    Int?           @map("pi_record_id")
  piRecord      OrderPiRecord? @relation(fields: [piRecordId], references: [id])
  fromDate      DateTime?      @map("from_date")
  toDate        DateTime?      @map("to_date")
  note          String?        @map("note")
  rescheduledAt DateTime       @default(now()) @map("rescheduled_at")

  @@map("order_piRescheduleLog")
}

// --- Parallel financial track B: Retention (RetentionPage.jsx) -----------

model OrderRetentionRecord {
  id             Int       @id @default(autoincrement())
  poNumber       String?   @unique @map("po_number")
  amountReceived Float?    @map("amount_received")
  status         String?   @default("Pending") @map("status") // 'Pending' | 'Partial' | 'Paid'
  remarks        String?   @map("remarks")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @map("updated_at")

  @@map("order_retentionRecord")
}

