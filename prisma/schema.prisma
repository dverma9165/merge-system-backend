// --- Delivery-side root — created either by Invoice (TC not required) or TC

model OrderDelivery {
  id                          Int            @id @default(autoincrement())
  timestamp                   DateTime?      @map("Timestamp")
  billDate                    DateTime?      @map("Bill Date")
  doNumber                    String?        @map("Delivery Order No.")
  partyName                   String?        @map("Party Name")
  productName                 String?        @map("Product Name")
  quantityDelivered           Float?         @map("Quantity Delivered.")
  billNo                      String?        @map("Bill No.")
  logisticNo                  String?        @map("Losgistic no.") // sic, preserved from reference
  rateOfMaterial              Float?         @map("Rate Of Material")
  typeOfTransporting          String?        @map("Type Of Transporting")
  transporterName             String?        @map("Transporter Name")
  vehicleNumber               String?        @map("Vehicle Number.")
  biltyNumber                 String?        @map("Bilty Number.")
  givingFromWhere             String?        @map("Giving From Where")
  indentNo                    String?        @map("Indent No.")
  qty                         Float?         @map("Qty")
  actualQtyLoadedInTruck      Float?         @map("Actual Qty loaded In Truck (Total Qty)")
  actualQtyAsPerWeighmentSlip Float?         @map("Actual Qty As Per Weighment Slip")
  imageOfSlip                 String?        @map("Image Of Slip")
  imageOfSlip2                String?        @map("Image Of Slip2")
  imageOfSlip3                String?        @map("Image Of Slip3")
  remarks                     String?        @map("Remarks")
  dSrNumber                   String?        @map("D-Sr Number")
  dispatchId                  Int?           @map("dispatch_id")
  dispatch                    OrderDispatch? @relation(fields: [dispatchId], references: [id])
  createdAt                   DateTime       @default(now()) @map("created_at")
  updatedAt                   DateTime?      @map("updated_at")

  bilty            OrderBilty?
  crm              OrderCrm?
  materialReceipts OrderMaterialReceipt[]

  @@map("order_delivery")
}

// --- Step 15: Bilty half of the shared "UnifiedLogistics.jsx" page (routed

model OrderBilty {
  id         Int            @id @default(autoincrement())
  deliveryId Int?           @unique @map("delivery_id")
  delivery   OrderDelivery? @relation(fields: [deliveryId], references: [id])
  biltyNo    String?        @map("Bilty No.")
  biltyCopy  String?        @map("Bilty Copy")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime?      @map("updated_at")

  @@map("order_bilty")
}

// Material Receipt half of the same shared page, mirrors "POST DELIVERY".

model OrderMaterialReceipt {
  id                         Int            @id @default(autoincrement())
  timestamp                  DateTime?      @map("Timestamp")
  orderNo                    String?        @map("Order No.")
  typeOfBill                 String?        @map("Type of Bill")
  billNo                     String?        @map("Bill No.")
  billDate                   DateTime?      @map("Bill Date")
  partyName                  String?        @map("Party Name")
  totalBillAmount            Float?         @map("Total Bill Amount")
  totalTruckQty              Float?         @map("Total Truck Qty")
